	#  GENERAL
	PORT = 4010
	PROSPECTING_PORT = 4002
	ENVIRONMENT_NAME = local
    APPLICATION_URL = https://local.getprojectshub.com
	DASHBOARD = true
	CHANCE_SEED="chance_seed"
	SESSION_SECRET=secret
	#SENDGRID — required in production for athlete invite emails
	SENDGRID_KEY = ''
	SENDGRID_FROM_EMAIL = 'invites@trackrecord.app'
	SENDGRID_FROM_NAME = 'TrackRecord'

	# POSTGRES (Drizzle)
	DATABASE_URL=postgres://localhost:5432/trackrecord
	TEST_DATABASE_URL=postgres://localhost:5432/trackrecord_test

	#REDIS
	REDIS_URL=redis://localhost:6379

	#TRACKING
	SENTRY_CONFIG = ''

	#CLERK
	CLERK_P_SECRET=
    CLERK_SECRET_KEY=

# RevenueCat — required in production (webhook rejects requests if secret is empty)
# Authorization header on the RC webhook must be: Bearer <REVENUECAT_WEBHOOK_SECRET>
REVENUECAT_WEBHOOK_SECRET=
# Optional server-side RC API key (sk_…) for future admin tooling — never ship to mobile
REVENUECAT_SECRET_API_KEY=

# R2 — bucket name must match Cloudflare exactly (no spaces after =)
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Public URL for playing videos in the app — enable Public Access on the bucket in Cloudflare, then paste the r2.dev URL here (NOT the .r2.cloudflarestorage.com upload URL)
CLOUDFLARE_R2_PUBLIC_URL=