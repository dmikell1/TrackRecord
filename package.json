{
	"name": "trackrecord-api",
	"version": "1.0.0",
	"packageManager": "pnpm@9.15.9",
	"main": "index.js",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "rm -rf build && (tsc -p tsconfig.build.json || true) && tsc-alias -p tsconfig.build.json --resolve-full-paths",
		"dev": "nodemon",
		"start:api-core": "SERVICE_NAME=api-core PORT=4010 node -r dotenv/config ./build/api-core/src/index.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "TS_NODE_TRANSPILE_ONLY=true node -r dotenv/config -r ts-node/register -r tsconfig-paths/register scripts/seedDummyData.ts",
		"db:seed:reset": "SEED_RESET=1 TS_NODE_TRANSPILE_ONLY=true node -r dotenv/config -r ts-node/register -r tsconfig-paths/register scripts/seedDummyData.ts",
		"test": "jest",
		"test:ci": "jest --ci",
		"lint": "eslint \"./api-*/**/*.ts\" --cache",
		"lint:ci": "eslint \"./api-*/**/*.ts\" --cache --cache-location ./.tmp/.eslintcache --cache-strategy content",
		"sentry:sourcemaps": "sentry-cli sourcemaps inject --org trackrecord ./build && sentry-cli sourcemaps upload --org trackrecord ./build"
	},
	"author": "DeSean Prentice",
	"license": "ISC",
	"description": "",
	"dependencies": {
		"@apollo/server": "^4.12.0",
		"@graphql-tools/schema": "^10.0.10",
		"@bull-board/api": "^6.10.0",
		"@bull-board/express": "^6.10.0",
		"@clerk/backend": "^3.4.4",
		"@dqbd/tiktoken": "^1.0.22",
		"@langchain/anthropic": "^1.3.28",
		"@langchain/core": "^1.1.43",
		"@langchain/openai": "^1.4.5",
		"@sentry/node": "^9.0.0",
		"@sentry/profiling-node": "^9.0.0",
		"@tsconfig/node20": "^20.1.9",
		"axios": "^1.15.2",
		"bull": "^4.16.5",
		"cheerio": "^1.2.0",
		"connect-pg-simple": "^10.0.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"danger": "^12.3.3",
		"date-fns": "^3.6.0",
		"drizzle-orm": "^0.44.2",
		"dotenv": "^16.5.0",
		"envalid": "^8.1.1",
		"express": "^4.21.0",
		"express-fileupload": "^1.5.2",
		"express-session": "^1.18.2",
		"graphql": "^16.13.2",
		"graphql-middleware": "^6.1.35",
		"graphql-redis-subscriptions": "^2.7.0",
		"graphql-shield": "^7.6.5",
		"graphql-tag": "^2.12.6",
		"graphql-ws": "^5.16.0",
		"ioredis": "^5.4.1",
		"limiter": "^2.1.0",
		"pino": "^10.1.0",
		"pino-http": "^10.4.0",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.5",
		"puppeteer": "^23.11.0",
		"reflect-metadata": "^0.2.2",
		"robots-parser": "^3.0.1",
		"tsyringe": "^4.10.0",
		"uuid4": "^2.0.3",
		"validator": "^13.15.35",
		"ws": "^8.18.0",
		"zod": "^4.2.1",
		"@aws-sdk/client-s3": "^3.797.0",
		"@aws-sdk/s3-request-presigner": "^3.797.0"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.29.3",
		"@babel/preset-typescript": "^7.28.5",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.15.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"chance": "^1.1.13",
		"eslint": "^8.57.0",
		"eslint-import-resolver-typescript": "^3.10.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jest": "^28.11.0",
		"eslint-plugin-prettier": "^5.5.5",
		"jest": "^29.7.0",
		"jest-mock-extended": "^4.0.1",
		"lint-staged": "^15.5.0",
		"nodemon": "^3.1.14",
		"ts-jest": "^29.4.9",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"drizzle-kit": "^0.31.0"
	}
}
