{
	"extends": "./tsconfig.json",
	"include": [
		"**/*.d.ts",
		"api-core/**/*",
		"api-prospecting/**/*",
		"packages/**/*"
	],
	"exclude": [
		"**/*.test.ts",
		"**/*.spec.ts"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@api-core/*": [
				"api-core/*"
			],
			"@api-prospecting/*": [
				"api-prospecting/*"
			],
			"@test-utils/*": [
				"test-utils/*"
			],
			"@packages/*": [
				"packages/*"
			],
			"@builders/*": [
				"test-utils/builders/*"
			]
		}
	}
}
